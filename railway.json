{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn clean package"
  },
  "deploy": {
    "startCommand": "java -jar /app/bot.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "sleepApplication": false,
    "healthcheckPath": null,
    "healthcheckTimeout": 0
  }
}

